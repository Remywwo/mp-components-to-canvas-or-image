.card {
  width: 750rpx;
  padding: 64rpx 52rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  background: #ffffff;
  border-radius: 32rpx;
}

.eyebrow {
  font-size: 24rpx;
  line-height: 1.2;
  color: #64748b;
  font-weight: 700;
}

.title {
  font-size: 56rpx;
  line-height: 1.18;
  color: #111827;
  font-weight: 700;
}

.body {
  font-size: 30rpx;
  line-height: 1.7;
  color: #334155;
}

.footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.author,
.date {
  font-size: 24rpx;
  line-height: 1.2;
  color: #64748b;
}
