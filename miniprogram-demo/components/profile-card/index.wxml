<view class="profile-card">
  <view class="profile-head">
    <image class="avatar" src="{{avatar}}" mode="aspectFill" />
    <view class="identity">
      <text class="name">{{name}}</text>
      <text class="role">{{role}}</text>
    </view>
    <text class="badge">{{badge}}</text>
  </view>
  <text class="summary">{{summary}}</text>
</view>
