.product-card {
  width: 750rpx;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  background: #111827;
  border-radius: 32rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  object-fit: cover;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.label {
  font-size: 22rpx;
  line-height: 1.2;
  color: #93c5fd;
  font-weight: 700;
}

.title {
  font-size: 48rpx;
  line-height: 1.16;
  color: #ffffff;
  font-weight: 700;
}

.description {
  font-size: 28rpx;
  line-height: 1.6;
  color: #cbd5e1;
}

.meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.price {
  font-size: 38rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 700;
}

.note {
  font-size: 24rpx;
  line-height: 1.2;
  color: #94a3b8;
}
