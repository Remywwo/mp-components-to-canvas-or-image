.metrics-card {
  width: 686rpx;
  min-height: 700rpx;
  padding: 44rpx;
  gap: 28rpx;
  display: flex;
  flex-direction: column;
  background-color: #f8fafc;
  border-radius: 28rpx;
  color: #0f172a;
}

.metrics-kicker {
  color: #0369a1;
  font-size: 22rpx;
  font-weight: 700;
}

.metrics-title {
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 700;
}

.metrics-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.metric-item {
  padding: 28rpx;
  gap: 8rpx;
  display: flex;
  flex-direction: column;
  background-color: #e2e8f0;
  border-radius: 18rpx;
}

.metric-item.accent {
  background-color: #dbeafe;
}

.metric-value {
  color: #0f172a;
  font-size: 46rpx;
  font-weight: 700;
}

.metric-label {
  color: #475569;
  font-size: 24rpx;
}

.metrics-note {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
}
