<view class="page">
  <view class="toolbar">
    <button class="primary" bindtap="renderCard" loading="{{rendering}}">渲染卡片</button>
    <button bindtap="exportImage" disabled="{{!ready}}">导出图片</button>
  </view>

  <view class="demo-tabs">
    <view
      wx:for="{{demos}}"
      wx:key="id"
      data-index="{{index}}"
      class="demo-tab {{selectedIndex === index ? 'active' : ''}}"
      bindtap="selectDemo"
    >
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="canvas-wrap">
    <share-card id="shareCard" width="{{359}}" height="{{560}}"></share-card>
  </view>

  <view wx:if="{{imagePath}}" class="result">
    <text class="label">导出结果</text>
    <image class="preview" mode="widthFix" src="{{imagePath}}" />
  </view>
</view>
