<view class="page">
  <view class="toolbar">
    <button class="primary" bindtap="renderByComponent" loading="{{rendering}}">组件渲染</button>
    <button bindtap="exportImage" disabled="{{!ready}}">导出图片</button>
  </view>

  <view class="toolbar secondary">
    <button bindtap="renderByPackageApi" loading="{{apiRendering}}">npm API 预检</button>
  </view>

  <view class="demo-tabs">
    <view
      wx:for="{{demos}}"
      wx:key="id"
      data-index="{{index}}"
      class="demo-tab {{selectedIndex === index ? 'active' : ''}}"
      bindtap="selectDemo"
    >
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="status">
    <text>{{status}}</text>
  </view>

  <view class="canvas-wrap">
    <share-card
      id="shareCard"
      class="share-card"
      width="{{343}}"
      height="{{520}}"
      render-options="{{renderOptions}}"
      render-key="{{renderKey}}"
      export-key="{{exportKey}}"
      bind:ready="onShareCardReady"
      bind:rendered="onShareCardRendered"
      bind:exported="onShareCardExported"
      bind:error="onShareCardError"
    ></share-card>
  </view>

  <view wx:if="{{imagePath}}" class="result">
    <text class="label">导出结果</text>
    <image class="preview" mode="widthFix" src="{{imagePath}}" />
  </view>
</view>
